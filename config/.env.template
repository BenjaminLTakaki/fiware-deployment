# ============================================================================
# FIWARE Data Space Connector - Environment Configuration Template
# ============================================================================
# Copy this file to .env.production or .env.development and configure values.
# The deployment script will automatically source the appropriate file.
#
# Usage:
#   cp .env.template .env.production
#   # Edit .env.production with your values
#   ./fiware_deployment.sh
# ============================================================================

# ======================== NETWORK CONFIGURATION ========================
# Internal IP address of the deployment VM
#
# For NetLab VMs: Leave empty for auto-detection. The script will:
#   1. Detect available IPs (filtering out Docker/K8s internal IPs)
#   2. Show you all available interfaces
#   3. Cache the IP for subsequent runs on the same VM
#
# If auto-detection fails or picks the wrong IP, either:
#   - Set INTERNAL_IP here, or
#   - Pass IP as argument: ./fiware_deployment.sh 192.168.x.x
#
INTERNAL_IP=

# Domain suffix for service URLs (default: nip.io for wildcard DNS)
# nip.io provides wildcard DNS: <anything>.<IP>.nip.io resolves to <IP>
DOMAIN_SUFFIX=nip.io

# ======================== SECURITY CONFIGURATION ========================
# Enable TLS verification in smoke tests (recommended for production)
TLS_VERIFY_ENABLED=true

# Enable machine-to-machine authentication
M2M_AUTH_ENABLED=false

# ======================== LOGGING CONFIGURATION ========================
# Log level for FIWARE components (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Enable debug mode (more verbose output)
DEBUG_ENABLED=false

# ======================== COMPONENT VERSIONS ========================
# Pin specific versions for reproducibility
#
# TESTED COMMITS (chart versions):
#   0b78cdaf7573cbd1852e2541afe0acb816c6caa5 -> 8.5.2 (recommended)
#   Use 'git log --oneline' in data-space-connector repo to find others
#
# To use a different version:
#   1. Set FIWARE_COMMIT to the desired commit hash
#   2. Run deployment - it will detect and validate the chart version
#   3. If version is untested, you'll be prompted to confirm
#
FIWARE_COMMIT=0b78cdaf7573cbd1852e2541afe0acb816c6caa5
YQ_VERSION=v4.45.1
HEADLAMP_CHART_VERSION=0.25.0

# Skip version compatibility check (use with caution on untested versions)
SKIP_VERSION_CHECK=false

# ======================== DATABASE CONFIGURATION ========================
# Storage class for persistent volumes
POSTGRES_STORAGE_CLASS=local-path
MYSQL_STORAGE_CLASS=local-path

# Enable database persistence (recommended for research)
DB_PERSISTENCE_ENABLED=true

# ======================== KUBERNETES CONFIGURATION ========================
# Namespace names (defaults work for most deployments)
NAMESPACE_INFRA=infra
NAMESPACE_PROVIDER=provider
NAMESPACE_CONSUMER=consumer
NAMESPACE_TRUST_ANCHOR=trust-anchor

# ======================== DEPLOYMENT OPTIONS ========================
# Skip Maven build if already built (for faster re-deployments)
SKIP_MAVEN_BUILD=false

# Deploy monitoring stack (Prometheus/Grafana)
DEPLOY_MONITORING=false

# Deploy logging stack (Loki/Promtail)
DEPLOY_LOGGING=false

# ======================== TIMEOUTS (seconds) ========================
# Pod readiness timeout
POD_READY_TIMEOUT=300

# Deployment timeout
DEPLOY_TIMEOUT=600

# ======================== RESEARCH CONFIGURATION ========================
# Enable additional instrumentation for research purposes
RESEARCH_MODE=true

# Data collection directory for experiments
RESEARCH_DATA_DIR=/fiware/research-data

# ======================== CUSTOM OVERRIDES ========================
# Add any custom environment variables below this line
